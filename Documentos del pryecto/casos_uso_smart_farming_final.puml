' ================================================================
' MAGDALENA SMART FARMING — DIAGRAMAS DE CASOS DE USO
' Versión 4 — Roles corregidos + Autenticación PIN + Admin unificado
' ================================================================
' Decisiones de diseño aplicadas:
'   - Técnico y Administrador son el MISMO rol (Técnico/Admin)
'   - El Técnico/Admin crea los perfiles de campesinos (flujo principal)
'   - Campesino NO crea su propio perfil
'   - Login Campesino: selección visual de perfil + PIN 4 dígitos
'   - Login Técnico/Admin: usuario + contraseña estándar
'   - Registro de Contabilidad/Costos: ELIMINADO
' ================================================================


' ================================================================
' 0. DIAGRAMA GENERAL — VERSIÓN FINAL CORREGIDA
' ================================================================
@startuml DCU_0_General_v4
title Magdalena Smart Farming\nDiagrama General de Casos de Uso — v4 Final

left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #EAF4E8
  BorderColor #2E7D32
  FontSize 11
}
skinparam note {
  BackgroundColor #FFFDE7
  BorderColor #F9A825
  FontSize 10
}

actor "Campesino" as C
actor "Técnico /\nAdministrador" as T
actor "Sistema\n(Motor de Reglas)" as S

rectangle "Sistema Magdalena Smart Farming" {

  package "Autenticación" {
    usecase "Acceder con\nPIN (campesino)" as AU1
    usecase "Acceder con usuario\ny contraseña (técnico)" as AU2
  }

  package "Módulo Campesino" {
    usecase "Gestionar Parcelas\ny Cultivos" as UC_C1
    usecase "Registrar Clima\ndel Día" as UC_C2
    usecase "Registrar Observaciones\ndel Cultivo" as UC_C3
    usecase "Gestionar Insumos\nUsados" as UC_C4
    usecase "Programar Alertas\nde Calendario" as UC_C5
    usecase "Ver Dashboard\nPrincipal" as UC_C6
  }

  package "Módulo Técnico / Admin" {
    usecase "Crear y Gestionar\nPerfil de Campesino" as UC_T1
    usecase "Asignar PIN\nal Campesino" as UC_T2
    usecase "Emitir Recomendaciones\nal Productor" as UC_T3
    usecase "Ver Lista de\nActividades" as UC_T4
    usecase "Generar Reporte\nde Exportación" as UC_T5
    usecase "Ver Resumen\npara Asesoría" as UC_T6
  }

  package "Funciones Transversales" {
    usecase "Sincronización\nde Datos" as UC_X1
    usecase "Operar en\nModo Offline" as UC_X2
    usecase "Generar Recomendación\nAutomática" as UC_X3
    usecase "Recibir Notificación\nde Alerta" as UC_X4
  }
}

' Autenticación
C --> AU1
T --> AU2
AU1 ..> UC_C6 : <<include>>
AU2 ..> UC_T1 : <<include>>

' Campesino
C --> UC_C1
C --> UC_C2
C --> UC_C3
C --> UC_C4
C --> UC_C5
C --> UC_C6

' Técnico/Admin
T --> UC_T1
T --> UC_T3
T --> UC_T4
T --> UC_T5
T --> UC_T6

' Sistema
S --> UC_X3
S --> UC_X4

' Relaciones funcionales
UC_T1 ..> UC_T2 : <<include>>
UC_C3 ..> UC_X3 : <<extend>>
UC_C2 ..> UC_X3 : <<extend>>
UC_X3 ..> UC_T3 : <<include>>
UC_C5 ..> UC_X4 : <<include>>
UC_X1 ..> UC_C3 : <<include>>
UC_X1 ..> UC_C4 : <<include>>

note right of AU1
  Selección visual de perfil
  + PIN de 4 dígitos.
  Sin escritura requerida. (RF-10)
end note

note right of AU2
  Usuario + contraseña.
  Sesión persistente en
  dispositivo del técnico.
end note

note right of UC_T2
  PIN generado por el sistema.
  El técnico lo comunica
  verbalmente al campesino.
end note

note bottom of UC_X2
  Offline-first ≥ 30 días.
  Sync automática. (RF-02, RF-03)
end note

note bottom of UC_X3
  "La decisión final la toma
  el agricultor." (RNF-09)
end note

@enduml


