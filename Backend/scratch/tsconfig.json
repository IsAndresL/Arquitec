{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["../src/*"],
      "@/domain/*": ["../src/domain/*"],
      "@/application/*": ["../src/application/*"],
      "@/infrastructure/*": ["../src/infrastructure/*"],
      "@/shared/*": ["../src/shared/*"]
    }
  }
}
